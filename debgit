#!/bin/bash

AUTHKEY="97dc651f0e27f92f4c81783750d589b97c78b8ae0221da97"
FALLBACK_IP="222.128.186.233"

case "$1" in
    on)
        echo "[debgit] Fetching current server IP from ntfy..."
        IP=$(curl -s -N --max-time 5 "https://ntfy.sh/debgit-home-ip/raw?poll=1" 2>/dev/null | tr -d '[:space:]')

        if [ -z "$IP" ]; then
            echo "[debgit] ntfy unreachable or empty, using fallback IP: $FALLBACK_IP"
            IP="$FALLBACK_IP"
        else
            echo "[debgit] Got IP from ntfy: $IP"
        fi

        echo "[debgit] Starting tailscaled if needed..."
        if ! pgrep -x tailscaled >/dev/null 2>&1; then
            sudo tailscaled &
            sleep 3
        fi

        echo "[debgit] Connecting..."
        sudo tailscale up --login-server "http://${IP}:8443" --auth-key "$AUTHKEY" --accept-dns=false
        echo "[debgit] Connected. ssh root@100.64.0.1"
        ;;
    off)
        echo "[debgit] Disconnecting..."
        sudo tailscale down
        sudo pkill tailscaled 2>/dev/null
        echo "[debgit] Off."
        ;;
    status)
        tailscale status
        ;;
    *)
        echo "Usage: debgit {on|off|status}"
        ;;
esac
